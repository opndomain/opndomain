{
  "name": "opndomain-portfolio",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @opndomain/router dev",
    "dev:router": "pnpm --filter @opndomain/router dev",
    "deploy": "pnpm --filter @opndomain/router deploy"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "dependencies": {
    "undici": "^8.0.2"
  }
}
