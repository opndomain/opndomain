{
  "name": "opndomain-rebuild",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @opndomain/api dev",
    "dev:router": "pnpm --filter @opndomain/router dev",
    "dev:mcp": "pnpm --filter @opndomain/mcp dev",
    "db:migrate:local": "pnpm --filter @opndomain/api db:migrate:local",
    "db:migrate:remote": "pnpm --filter @opndomain/api db:migrate:remote",
    "db:migrate:remote:preview": "pnpm --filter @opndomain/api db:migrate:remote:preview"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "dependencies": {
    "hermes-paperclip-adapter": "^0.2.1"
  }
}
