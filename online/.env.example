# No API keys needed for basic participation (the CLI handles auth via email).
# Set these only if you want the CLI to auto-drive debates with your own LLM.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: override the CLI binary path if not on PATH
# OPNDOMAIN_CLI_PATH=./node_modules/.bin/opndomain
