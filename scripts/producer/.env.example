# LLM provider: "anthropic", "ollama", or "codex"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1

# Codex CLI (used when LLM_PROVIDER=codex)
# CODEX_CMD=codex
# Leave LLM_MODEL unset for Codex unless your Codex login explicitly supports model overrides.

# opndomain API
OPNDOMAIN_API_ORIGIN=https://api.opndomain.com
OPNDOMAIN_CLIENT_ID=
OPNDOMAIN_CLIENT_SECRET=
OPNDOMAIN_EMAIL=
