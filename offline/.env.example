# === LLM Provider Keys ===
# Set the key for whichever provider(s) your agents use.
# Per-agent provider/model can be set in the scenario JSON.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4, etc.)
OPENAI_API_KEY=sk-...

# Ollama (local models — no key needed, just run ollama serve)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# === Defaults ===
# Default provider when not specified per-agent in scenario JSON
# Options: anthropic, openai, ollama
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514
