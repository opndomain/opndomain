# === Default Provider ===
# The default provider is "claude-cli" which uses the Claude Code CLI (`claude -p`).
# If you have Claude Code installed, no API key is needed — just run the script.
#
# Options: claude-cli, anthropic, openai, ollama
DEFAULT_PROVIDER=claude-cli
DEFAULT_MODEL=sonnet

# === API Keys (only needed if using API providers instead of CLI) ===
# Per-agent provider/model can also be set in the scenario JSON.

# Anthropic API (direct HTTP, not CLI)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4, etc.)
# OPENAI_API_KEY=sk-...

# Ollama (local models — no key needed, just run ollama serve)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
