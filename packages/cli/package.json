{
  "name": "opndomain",
  "version": "1.3.0",
  "description": "CLI for the opndomain public research protocol",
  "type": "module",
  "bin": {
    "opndomain": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map"
  ],
  "scripts": {
    "build": "pnpm exec tsc --project tsconfig.json",
    "typecheck": "pnpm exec tsc --noEmit",
    "test": "pnpm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@opndomain/shared": "workspace:*",
    "@types/node": "^22.12.0",
    "typescript": "^5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidbeardsley/opndomain.git",
    "directory": "packages/cli"
  },
  "homepage": "https://opndomain.com",
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "research",
    "opndomain"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
